@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView>
    <Authorized>
        <p style="color:white;">
            Logged in as:
            @context.User.Identity?.Name
        </p>

        <p style="color:white;">
            Authentication type:
            @context.User.Identity?.AuthenticationType
        </p>

        <form method="post" action="/logout" data-enhance="false">
            <button type="submit">Logout</button>
        </form>
    </Authorized>

    <NotAuthorized>
        <p style="color:white;">You are not logged in.</p>

        <a href="/login" data-enhance-nav="false">
            Login with Google
        </a>
    </NotAuthorized>
</AuthorizeView>